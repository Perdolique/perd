{
  "name": "perd",
  "private": true,
  "type": "module",
  "imports": {
    "#server/*": "./server/*.ts",
    "#shared/*": "./shared/*.ts"
  },
  "scripts": {
    "build": "pnpm exec nuxt build",
    "db:generate": "pnpm exec drizzle-kit generate",
    "db:migrate:local": "pnpm exec tsx --env-file=.env ./tools/migrate.ts",
    "db:migrate": "pnpm exec tsx ./tools/migrate.ts",
    "db:seed": "pnpm exec tsx ./tools/seed.ts",
    "db:seed:local": "pnpm exec tsx --env-file=.env ./tools/seed.ts",
    "deploy:production": "pnpm exec wrangler deploy --env=production",
    "deploy:staging": "pnpm exec wrangler deploy --env=staging",
    "deploy:versions:staging": "pnpm exec wrangler versions upload --env=staging",
    "dev": "pnpm exec nuxt dev",
    "drizzle": "pnpm exec drizzle-kit",
    "lint:markdown": "pnpm exec markdownlint '**/*.md'",
    "lint:oxlint": "pnpm exec oxlint",
    "lint:oxlint:agent": "pnpm exec oxlint --format agent",
    "postinstall": "pnpm exec nuxt prepare",
    "preview": "pnpm exec wrangler dev",
    "preview:e2e": "mkdir -p /tmp/perd-e2e/config /tmp/perd-e2e/cache /tmp/perd-e2e/state /tmp/perd-e2e/logs /tmp/perd-e2e/home && XDG_CONFIG_HOME=/tmp/perd-e2e/config XDG_CACHE_HOME=/tmp/perd-e2e/cache XDG_STATE_HOME=/tmp/perd-e2e/state WRANGLER_LOG_PATH=/tmp/perd-e2e/logs WRANGLER_CACHE_DIR=/tmp/perd-e2e/cache/wrangler CLOUDFLARE_HOME=/tmp/perd-e2e/home pnpm run build && XDG_CONFIG_HOME=/tmp/perd-e2e/config XDG_CACHE_HOME=/tmp/perd-e2e/cache XDG_STATE_HOME=/tmp/perd-e2e/state WRANGLER_LOG_PATH=/tmp/perd-e2e/logs WRANGLER_CACHE_DIR=/tmp/perd-e2e/cache/wrangler CLOUDFLARE_HOME=/tmp/perd-e2e/home pnpm run preview",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:ci": "CI=true pnpm exec playwright test",
    "test:typecheck": "pnpm exec nuxi typecheck",
    "test:unit": "pnpm exec vitest",
    "test:unit:ci": "pnpm exec vitest run",
    "test:unit:agent": "pnpm exec vitest run --reporter agent",
    "update:all": "pnpm exec taze --interactive --include-locked",
    "prepare": "pnpm exec husky"
  },
  "dependencies": {
    "@nuxt/hints": "1.1.1",
    "delay": "7.0.0",
    "nuxt": "4.4.4",
    "vue": "3.5.33"
  },
  "devDependencies": {
    "@iconify-json/streamline-emojis": "1.2.4",
    "@iconify-json/tabler": "1.2.33",
    "@neondatabase/serverless": "1.1.0",
    "@nuxt/devtools": "4.0.0-alpha.4",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.2.2",
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.0",
    "@types/ws": "8.18.1",
    "@vueuse/core": "14.3.0",
    "drizzle-kit": "1.0.0-beta.23",
    "drizzle-orm": "1.0.0-beta.23",
    "drizzle-seed": "1.0.0-beta.23",
    "eslint-config-greenpie": "16.0.0-11",
    "husky": "9.1.7",
    "markdownlint": "0.40.0",
    "markdownlint-cli": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "taze": "19.11.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "ufo": "1.6.4",
    "valibot": "1.3.1",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "vue-tsc": "3.2.8",
    "wrangler": "4.88.0",
    "ws": "8.20.0"
  },
  "packageManager": "pnpm@11.0.6",
  "overrides": {
    "@nuxt/devtools": "$@nuxt/devtools"
  }
}
