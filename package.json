{
  "name": "perd",
  "private": true,
  "type": "module",
  "imports": {
    "#server/*": "./server/*.ts",
    "#shared/*": "./shared/*.ts"
  },
  "scripts": {
    "build": "nuxt build",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "tsx --env-file=.env ./tools/migrate.ts",
    "db:migrate": "tsx ./tools/migrate.ts",
    "db:seed": "tsx ./tools/seed.ts",
    "db:seed:local": "tsx --env-file=.env ./tools/seed.ts",
    "deploy:production": "wrangler deploy --env=production",
    "deploy:staging": "wrangler deploy --env=staging",
    "deploy:versions:staging": "wrangler versions upload --env=staging",
    "dev": "nuxt dev",
    "drizzle": "drizzle-kit",
    "lint:markdown": "markdownlint '**/*.md'",
    "lint:oxlint": "oxlint",
    "lint:oxlint:agent": "oxlint --format agent",
    "postinstall": "nuxt prepare",
    "preview": "wrangler dev",
    "preview:e2e": "sh tools/preview-e2e.sh",
    "test:e2e": "playwright test",
    "test:e2e:ci": "CI=true playwright test",
    "test:typecheck": "nuxi typecheck",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run",
    "test:unit:agent": "vitest run --reporter agent",
    "update:all": "taze --interactive --include-locked",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/hints": "1.1.3",
    "@pinia/nuxt": "0.11.3",
    "delay": "7.0.0",
    "nuxt": "4.4.8",
    "pinia": "3.0.4",
    "vue": "3.5.39"
  },
  "devDependencies": {
    "@iconify-json/hugeicons": "1.2.30",
    "@neondatabase/serverless": "1.1.0",
    "@nuxt/devtools": "4.0.0-alpha.7",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.3.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/ws": "8.18.1",
    "@vueuse/core": "14.3.0",
    "drizzle-kit": "1.0.0-rc.4-ca0f029",
    "drizzle-orm": "1.0.0-rc.4-5d5b77c",
    "drizzle-seed": "1.0.0-rc.4-ca0f029",
    "eslint-config-greenpie": "17.1.0",
    "husky": "9.1.7",
    "markdownlint": "0.41.0",
    "markdownlint-cli": "0.49.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "taze": "19.14.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "ufo": "1.6.4",
    "valibot": "1.4.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7",
    "wrangler": "4.108.0",
    "ws": "8.21.0"
  },
  "packageManager": "pnpm@11.11.0",
  "overrides": {
    "@nuxt/devtools": "$@nuxt/devtools"
  }
}
