{
  "name": "perd",
  "private": true,
  "type": "module",
  "imports": {
    "#server/*": "./server/*.ts",
    "#shared/*": "./shared/*.ts"
  },
  "scripts": {
    "build": "nuxt build",
    "build:e2e": "nuxt build --dotenv tests/playwright/runtime.env",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "tsx --env-file=.env ./tools/migrate.ts",
    "db:migrate": "tsx ./tools/migrate.ts",
    "db:seed": "tsx ./tools/seed.ts",
    "db:seed:local": "tsx --env-file=.env ./tools/seed.ts",
    "deploy:production": "wrangler deploy --env=production",
    "deploy:staging": "wrangler deploy --env=staging",
    "deploy:versions:staging": "wrangler versions upload --env=staging",
    "dev": "nuxt dev",
    "drizzle": "drizzle-kit",
    "lint:markdown": "markdownlint '**/*.md'",
    "lint:oxlint": "oxlint",
    "lint:oxlint:agent": "oxlint --format agent",
    "postinstall": "nuxt prepare",
    "preview": "wrangler dev",
    "preview:e2e": "XDG_CONFIG_HOME=.output/e2e/config XDG_CACHE_HOME=.output/e2e/cache XDG_STATE_HOME=.output/e2e/state WRANGLER_LOG_PATH=.output/e2e/logs WRANGLER_CACHE_DIR=.output/e2e/cache/wrangler wrangler dev --local --env-file tests/playwright/runtime.env --persist-to .output/e2e/wrangler-state --ip 127.0.0.1 --port 8888 --log-level warn",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:ci": "CI=true playwright test",
    "test:typecheck": "nuxi typecheck",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run",
    "test:unit:agent": "vitest run --reporter agent",
    "update:all": "taze --interactive --include-locked",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/hints": "1.1.3",
    "@pinia/nuxt": "1.0.0",
    "delay": "7.0.0",
    "nuxt": "4.4.8",
    "pinia": "4.0.2",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@iconify-json/hugeicons": "1.2.31",
    "@neondatabase/serverless": "1.1.0",
    "@nuxt/devtools": "4.0.0-alpha.7",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.3.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/ws": "8.18.1",
    "@vueuse/core": "14.3.0",
    "drizzle-kit": "1.0.0-rc.4",
    "drizzle-orm": "1.0.0-rc.4",
    "drizzle-seed": "1.0.0-rc.4",
    "eslint-config-greenpie": "17.2.0",
    "husky": "9.1.7",
    "markdownlint": "0.41.1",
    "markdownlint-cli": "0.49.1",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "taze": "19.14.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "ufo": "1.6.4",
    "valibot": "1.4.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7",
    "wrangler": "4.110.0",
    "ws": "8.21.1"
  },
  "packageManager": "pnpm@11.13.0",
  "overrides": {
    "@nuxt/devtools": "$@nuxt/devtools"
  }
}
