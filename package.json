{
  "name": "perd",
  "private": true,
  "type": "module",
  "imports": {
    "#server/*": "./server/*.ts",
    "#shared/*": "./shared/*.ts"
  },
  "scripts": {
    "build": "nuxt build",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "tsx --env-file=.env ./tools/migrate.ts",
    "db:migrate": "tsx ./tools/migrate.ts",
    "db:seed": "tsx ./tools/seed.ts",
    "db:seed:local": "tsx --env-file=.env ./tools/seed.ts",
    "deploy:production": "wrangler deploy --env=production",
    "deploy:staging": "wrangler deploy --env=staging",
    "deploy:versions:staging": "wrangler versions upload --env=staging",
    "dev": "nuxt dev",
    "drizzle": "drizzle-kit",
    "lint:markdown": "markdownlint '**/*.md'",
    "lint:oxlint": "oxlint",
    "postinstall": "nuxt prepare",
    "preview": "wrangler dev",
    "preview:e2e": "pnpm run build && pnpm run preview",
    "test:e2e": "playwright test",
    "test:e2e:ci": "CI=true playwright test",
    "test:typecheck": "nuxi typecheck",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run",
    "test:unit:agent": "vitest run --reporter agent",
    "update:all": "taze --interactive --include-locked",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/hints": "1.0.3",
    "delay": "7.0.0",
    "nuxt": "4.4.2",
    "vue": "3.5.32"
  },
  "devDependencies": {
    "@iconify-json/streamline-emojis": "1.2.4",
    "@iconify-json/tabler": "1.2.33",
    "@neondatabase/serverless": "1.0.2",
    "@nuxt/devtools": "4.0.0-alpha.4",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.2.1",
    "@playwright/test": "1.59.1",
    "@types/node": "25.5.2",
    "@types/ws": "8.18.1",
    "@vueuse/core": "14.2.1",
    "drizzle-kit": "1.0.0-beta.22-1b8fcb2",
    "drizzle-orm": "1.0.0-beta.22-1b8fcb2",
    "drizzle-seed": "1.0.0-beta.22-1b8fcb2",
    "eslint-config-greenpie": "16.0.0-5",
    "husky": "9.1.7",
    "markdownlint": "0.40.0",
    "markdownlint-cli": "0.48.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "taze": "19.11.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "ufo": "1.6.3",
    "valibot": "1.3.1",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "vue-tsc": "3.2.6",
    "wrangler": "4.81.0",
    "ws": "8.20.0"
  },
  "packageManager": "pnpm@10.33.0",
  "overrides": {
    "@nuxt/devtools": "$@nuxt/devtools"
  }
}
